# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow any moderator who logs in with phone + OTP.
ADMIN_TELEGRAM_IDS=

# ArenaTop API
ARENATOP_API_BASE_URL=https://api.arenatop.uz/v1

# Optional: static token (if set, phone OTP login is skipped)
# ARENATOP_API_TOKEN=

# How often to check for new requests (seconds)
POLL_INTERVAL_SECONDS=60

# Optional: only notify for items with these statuses (comma-separated, empty = all)
REFUND_STATUSES=pending
WITHDRAWAL_STATUSES=pending
